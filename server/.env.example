# --- Salesforce Connected App / External Client App ---
# Find these in Salesforce Setup → External Client App Manager → your app → Settings → OAuth Settings.
SF_CLIENT_ID=your-consumer-key-here
SF_CLIENT_SECRET=your-consumer-secret-here

# Use https://login.salesforce.com for production orgs and Developer Edition orgs.
# Use https://test.salesforce.com if you ever target a sandbox.
SF_LOGIN_URL=https://login.salesforce.com

# Must EXACTLY match the Callback URL configured on your Connected/External Client App.
SF_CALLBACK_URL=http://localhost:3000/auth/callback

# --- Server ---
PORT=3000
NODE_ENV=development

# Long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Where the React app runs in dev. Used for the post-OAuth redirect and for CORS.
CLIENT_ORIGIN=http://localhost:5173
